rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function roleFromClaims() {
      return isAuthenticated() ? request.auth.token.role : null;
    }

    function isAdminRole() {
      return isAuthenticated() && roleFromClaims() in ['admin', 'super_admin'];
    }

    function isOwnerRole() {
      return isAuthenticated() && roleFromClaims() == 'owner';
    }

    function merchantBelongsToUser(merchantId) {
      let merchant = firestore.get(/databases/(default)/documents/merchants/$(merchantId));
      return isAuthenticated()
        && merchant.data != null
        && merchant.data.ownerUserId == request.auth.uid;
    }

    function isValidImageUpload() {
      return request.resource != null
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    function isValidClaimEvidenceUpload() {
      return request.resource != null
        && request.resource.size <= 8 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        );
    }

    function claimBelongsToUser(claimId, userId) {
      let claim = firestore.get(/databases/(default)/documents/merchant_claims/$(claimId));
      return claim.data != null
        && claim.data.userId == userId;
    }

    // Imágenes de comercios — lectura pública para no romper UX de ficha pública.
    // Escritura restringida por ownership documental o admin.
    match /merchants/{merchantId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminRole()
        || (
          isOwnerRole()
          && merchantBelongsToUser(merchantId)
          && (
            request.resource == null
            || isValidImageUpload()
          )
        );
    }

    // Imágenes de productos MVP:
    // path estricto merchant-products/{merchantId}/{productId}/cover.jpg
    // Se permite read público porque la ficha pública consume estas imágenes.
    match /merchant-products/{merchantId}/{productId}/{fileName} {
      allow read: if true;
      allow write: if isAdminRole()
        || (
          isOwnerRole()
          && merchantBelongsToUser(merchantId)
          && fileName == 'cover.jpg'
          && (
            request.resource == null
            || isValidImageUpload()
          )
        );
    }

    // Compatibilidad temporal con paths legacy de productos.
    match /products/{merchantId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminRole()
        || (
          isOwnerRole()
          && merchantBelongsToUser(merchantId)
          && (
            request.resource == null
            || isValidImageUpload()
          )
        );
    }

    // Avatares de usuarios
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Evidencias de claims de titularidad (privadas).
    // Path canónico: merchant-claims/{userId}/{claimId}/{fileName}
    match /merchant-claims/{userId}/{claimId}/{allPaths=**} {
      allow read: if isAdminRole()
        || (
          isAuthenticated()
          && request.auth.uid == userId
          && claimBelongsToUser(claimId, userId)
        );
      allow write: if isAdminRole()
        || (
          isAuthenticated()
          && request.auth.uid == userId
          && claimBelongsToUser(claimId, userId)
          && (
            request.resource == null
            || isValidClaimEvidenceUpload()
          )
        );
    }

    // Todo lo demás: denegado
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
