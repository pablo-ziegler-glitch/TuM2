{
  "name": "tum2-functions",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "npm run build && node --test lib/admin/__tests__/backfillKeywords.test.js lib/lib/__tests__/projection.test.js lib/lib/__tests__/operationalSignals.test.js lib/lib/__tests__/pharmacyDuties.test.js lib/lib/__tests__/pharmacyDutyMitigation.test.js lib/lib/__tests__/catalogLimits.test.js",
    "test:integration:pharmacy-duties": "npm run build && node --test lib/callables/__tests__/pharmacyDuties.integration.test.js",
    "cost:guard": "node scripts/firestore_cost_guard.js",
    "finops:summary": "node scripts/finops_summary.js",
    "finops:gate": "node scripts/finops_gate.js",
    "seed:zones:csv": "node scripts/seed_zones_from_csv.js",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "eslint --ext .ts src/"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.0.0",
    "geofire-common": "^6.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  },
  "private": true
}
