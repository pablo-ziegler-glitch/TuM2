rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: solo el propio usuario puede leer/escribir su documento
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Stores: lectura pública, escritura solo del owner
    match /stores/{storeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.ownerId;

      // Products: lectura pública, escritura solo del owner del store
      match /products/{productId} {
        allow read: if true;
        allow write: if request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId;
      }

      // Schedules: lectura pública, escritura solo del owner
      match /schedules/{scheduleId} {
        allow read: if true;
        allow write: if request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId;
      }

      // Operational signals: lectura pública, escritura solo del owner
      match /operationalSignals/{signalId} {
        allow read: if true;
        allow write: if request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId;
      }
    }

    // Duty schedules: lectura pública, escritura solo autenticados
    match /dutySchedules/{dutyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Proposals y votos del roadmap
    match /proposals/{proposalId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.createdBy;

      match /votes/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Branding snippets: solo lectura pública (escritura vía Admin SDK)
    match /brandingSnippets/{snippetId} {
      allow read: if true;
      allow write: if false;
    }

    // Badge definitions: solo lectura pública
    match /badgeDefinitions/{badgeId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
