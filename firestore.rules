rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function roleFromClaims() {
      return isAuthenticated() ? request.auth.token.role : null;
    }

    function isAdmin() {
      return isAuthenticated() && roleFromClaims() in ['admin', 'super_admin'];
    }

    function isSuperAdmin() {
      return isAuthenticated() && roleFromClaims() == 'super_admin';
    }

    function isOwnerRole() {
      return isAuthenticated() && roleFromClaims() == 'owner';
    }

    function merchantBelongsToUser(merchantId) {
      let claimMerchantId = isAuthenticated()
        && request.auth.token.merchantId is string
        ? request.auth.token.merchantId
        : null;
      let claimMerchantIds = isAuthenticated()
        && request.auth.token.merchantIds is list
        ? request.auth.token.merchantIds
        : [];
      return isAuthenticated()
        && (
          (claimMerchantId != null && claimMerchantId == merchantId)
          || (merchantId in claimMerchantIds)
        );
    }

    function merchantOwnedByAuthenticatedUser(merchantId) {
      return isAuthenticated() && merchantBelongsToUser(merchantId);
    }

    function isDutyPublicReadableStatus(status) {
      return status in [
        'scheduled',
        'active',
        'incident_reported',
        'replacement_pending',
        'reassigned',
        // Compatibilidad legacy
        'published'
      ];
    }

    // ─── users/{userId} ─────────────────────────────────────────────────────
    // Users can read/write their own document (except role field).
    // Admins can read all users.

    // Returns true if the draftMerchantId field is being changed after it was
    // already set. Prevents client-side replay attacks on the onboarding submit.
    // Nota: denegar también la eliminación del campo una vez que draftMerchantId
    // está asignado, para evitar el bypass: eliminar el campo y luego re-escribir
    // con un ID diferente eludiendo el control de inmutabilidad.
    function draftMerchantIdUnchanged() {
      let progress = 'onboardingOwnerProgress';
      let incoming = request.resource.data.get(progress, null);
      let existingProgress = resource.data.get(progress, null);
      let existingId = existingProgress == null
        ? null
        : existingProgress.get('draftMerchantId', null);
      let newId = incoming == null
        ? null
        : incoming.get('draftMerchantId', null);
      // Si el update elimina onboardingOwnerProgress, solo se permite
      // si aún no había un draftMerchantId asignado (no hay nada que proteger)
      return incoming == null
        ? existingId == null
        // Allow if it was null/unset before, or if it stays the same
        : existingId == null || existingId == newId;
    }

    function onboardingProgressExists() {
      return 'onboardingOwnerProgress' in resource.data
          && resource.data.onboardingOwnerProgress != null;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && (
          !('role' in request.resource.data)
          || request.resource.data.role == 'customer'
        );
      allow update: if isOwner(userId)
        && !('role' in request.resource.data.diff(resource.data).affectedKeys())
        && (!onboardingProgressExists() || draftMerchantIdUnchanged());
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ─── zones/{zoneId} ─────────────────────────────────────────────────────
    // Zones are publicly readable. Only admins can write.

    match /zones/{zoneId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── merchants/{merchantId} ──────────────────────────────────────────────
    // Public read for active+visible merchants.
    // Owners can write their own merchant (limited fields).
    // Admins can read/write all.

    match /merchants/{merchantId} {
      function isPublicMerchant() {
        return resource.data.visibilityStatus == 'visible'
          && resource.data.status == 'active';
      }

      function isOwnerOfThisMerchant() {
        return isAuthenticated()
          && resource.data.ownerUserId == request.auth.uid;
      }

      function ownerCreatePayloadIsValid() {
        return request.resource.data.ownerUserId == request.auth.uid
          && request.resource.data.sourceType == 'owner_created'
          && request.resource.data.visibilityStatus in ['hidden', 'review_pending']
          && request.resource.data.verificationStatus == 'unverified'
          && request.resource.data.status in ['draft', 'active'];
      }

      function ownerUpdatePayloadIsValid() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return request.resource.data.ownerUserId == request.auth.uid
          && !('ownerUserId' in changed)
          && !('verificationStatus' in changed)
          && !('visibilityStatus' in changed)
          && !('sourceType' in changed)
          && !('createdAt' in changed)
          // Límites/counters del catálogo solo backend/admin.
          && !('catalogLimits' in changed)
          && !('catalogStats' in changed);
      }

      allow get, list: if isPublicMerchant() || isOwnerOfThisMerchant() || isAdmin();

      allow create: if isAdmin();
      allow create: if isOwnerRole() && ownerCreatePayloadIsValid();

      allow update: if isAdmin();
      allow update: if isOwnerRole()
        && isOwnerOfThisMerchant()
        && ownerUpdatePayloadIsValid();

      allow delete: if isAdmin();

      // ─── Subcolecciones privadas de horarios OWNER ────────────────────────
      match /schedule_config/{docId} {
        allow read: if isOwnerRole() && merchantBelongsToUser(merchantId);
        allow read, write: if isAdmin();
        allow create, update: if isOwnerRole() && merchantBelongsToUser(merchantId);
        allow delete: if isAdmin();
      }

      match /schedule_exceptions/{date} {
        allow read: if isOwnerRole() && merchantBelongsToUser(merchantId);
        allow read, write: if isAdmin();
        allow create, update, delete: if isOwnerRole() && merchantBelongsToUser(merchantId);
      }

      match /schedule_exceptions_ranges/{rangeId} {
        allow read: if isOwnerRole() && merchantBelongsToUser(merchantId);
        allow read, write: if isAdmin();
        allow create, update, delete: if isOwnerRole() && merchantBelongsToUser(merchantId);
      }
      allow delete: if isOwnerRole() && isOwnerOfThisMerchant();
    }

    // ─── merchant_public/{merchantId} ────────────────────────────────────────
    // Public read only. Writes are handled exclusively by Cloud Functions.

    match /merchant_public/{merchantId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── merchant_schedules/{merchantId} ────────────────────────────────────
    // Public read. Owners write their own. Admins write all.

    match /merchant_schedules/{merchantId} {
      allow read: if true;
      allow write: if isAdmin();
      allow write: if isOwnerRole() && merchantBelongsToUser(merchantId);
    }

    // ─── merchant_operational_signals/{merchantId} ───────────────────────────
    // Privado owner/admin. merchant_public es la salida pública.

    match /merchant_operational_signals/{merchantId} {
      function allowedSignalKeys() {
        return [
          'merchantId',
          'ownerUserId',
          'signalType',
          'isActive',
          'message',
          'forceClosed',
          'updatedAt',
          'updatedByUid',
          'createdAt',
          'schemaVersion',
          // Campos derivados backend (se permiten persistidos, no editables por owner)
          'isOpenNow',
          'todayScheduleLabel',
          'hasPharmacyDutyToday',
          'hasScheduleConfigured',
          'closesAt',
          'opensNextAt',
          // Compatibilidad con esquema legacy de señales (migración progresiva).
          'signals',
          'derivedSignals',
          'sourceType',
          'updatedBy',
          'temporaryClosed',
          'temporaryClosedNote',
          'hasDelivery',
          'acceptsWhatsappOrders',
          'openNowManualOverride',
          'manualOverrides',
        ];
      }

      function isValidSignalType(value) {
        return value in ['none', 'vacation', 'temporary_closure', 'delay'];
      }

      function hasValidSignalMessage() {
        return !('message' in request.resource.data)
          || request.resource.data.message == null
          || (
            request.resource.data.message is string
            && request.resource.data.message.size() <= 80
            && !request.resource.data.message.matches('.*<[^>]*>.*')
            && !request.resource.data.message.matches('.*https?://.*')
            && !request.resource.data.message.matches('.*http://.*')
            && !request.resource.data.message.matches('.*https://.*')
          );
      }

      function ownerFieldsAreValidForCreate() {
        return request.resource.data.keys().hasOnly(allowedSignalKeys())
          && request.resource.data.merchantId is string
          && request.resource.data.merchantId == merchantId
          && request.resource.data.ownerUserId is string
          && request.resource.data.ownerUserId == request.auth.uid
          && request.resource.data.updatedByUid is string
          && request.resource.data.updatedByUid == request.auth.uid
          && request.resource.data.signalType is string
          && isValidSignalType(request.resource.data.signalType)
          && request.resource.data.isActive is bool
          && request.resource.data.forceClosed is bool
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.schemaVersion is int
          && request.resource.data.schemaVersion == 1
          && hasValidSignalMessage()
          && (
            (request.resource.data.signalType in ['vacation', 'temporary_closure']
              && request.resource.data.isActive == true
              && request.resource.data.forceClosed == true)
            || (request.resource.data.signalType == 'delay'
              && request.resource.data.isActive == true
              && request.resource.data.forceClosed == false)
            || (request.resource.data.signalType == 'none'
              && request.resource.data.isActive == false
              && request.resource.data.forceClosed == false)
          );
      }

      function ownerFieldsAreValidForUpdate() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return request.resource.data.keys().hasOnly(allowedSignalKeys())
          && request.resource.data.merchantId is string
          && request.resource.data.merchantId == merchantId
          && request.resource.data.ownerUserId is string
          && request.resource.data.ownerUserId == request.auth.uid
          && (
            !('ownerUserId' in resource.data)
            || request.resource.data.ownerUserId == resource.data.ownerUserId
          )
          && request.resource.data.updatedByUid is string
          && request.resource.data.updatedByUid == request.auth.uid
          && request.resource.data.signalType is string
          && isValidSignalType(request.resource.data.signalType)
          && request.resource.data.isActive is bool
          && request.resource.data.forceClosed is bool
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.schemaVersion is int
          && request.resource.data.schemaVersion == 1
          && (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt)
          && !('isOpenNow' in changed)
          && !('todayScheduleLabel' in changed)
          && !('hasPharmacyDutyToday' in changed)
          && !('hasScheduleConfigured' in changed)
          && !('closesAt' in changed)
          && !('opensNextAt' in changed)
          && hasValidSignalMessage()
          && (
            (request.resource.data.signalType in ['vacation', 'temporary_closure']
              && request.resource.data.isActive == true
              && request.resource.data.forceClosed == true)
            || (request.resource.data.signalType == 'delay'
              && request.resource.data.isActive == true
              && request.resource.data.forceClosed == false)
            || (request.resource.data.signalType == 'none'
              && request.resource.data.isActive == false
              && request.resource.data.forceClosed == false)
          );
      }

      allow read: if isAdmin() || (isOwnerRole() && merchantOwnedByAuthenticatedUser(merchantId));
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
      allow create: if isOwnerRole()
        && merchantOwnedByAuthenticatedUser(merchantId)
        && ownerFieldsAreValidForCreate();
      allow update: if isOwnerRole()
        && merchantOwnedByAuthenticatedUser(merchantId)
        && ownerFieldsAreValidForUpdate();
      allow delete: if false;
    }

    // ─── merchant_products/{productId} ──────────────────────────────────────
    // Public read of visible products. Owners write own merchant products.
    // Admins write all.

    match /merchant_products/{productId} {
      function requiredProductKeys() {
        return [
          'id',
          'merchantId',
          'ownerUserId',
          'name',
          'normalizedName',
          'priceLabel',
          'stockStatus',
          'visibilityStatus',
          'status',
          'sourceType',
          'createdAt',
          'updatedAt',
          'createdBy',
          'updatedBy',
        ];
      }

      function allowedProductKeys() {
        return [
          'id',
          'merchantId',
          'ownerUserId',
          'name',
          'normalizedName',
          'priceLabel',
          'stockStatus',
          'visibilityStatus',
          'status',
          'sourceType',
          'createdAt',
          'updatedAt',
          'createdBy',
          'updatedBy',
          'imageUrl',
          'imagePath',
          'imageUploadStatus',
          'searchKeywords',
          'sortOrder',
        ];
      }

      function hasValidProductKeys() {
        let keys = request.resource.data.keys();
        return keys.hasAll(requiredProductKeys()) && keys.hasOnly(allowedProductKeys());
      }

      function isValidProductStockStatus(value) {
        return value in ['available', 'out_of_stock'];
      }

      function isValidProductVisibilityStatus(value) {
        return value in ['visible', 'hidden'];
      }

      function isValidProductStatus(value) {
        return value in ['active', 'inactive'];
      }

      function isValidImageUploadStatus(value) {
        return value in ['pending', 'ready', 'failed'];
      }

      function hasValidProductTextFields() {
        return request.resource.data.name is string
          && request.resource.data.name.size() >= 2
          && request.resource.data.name.size() <= 80
          && request.resource.data.normalizedName is string
          && request.resource.data.normalizedName.size() >= 2
          && request.resource.data.normalizedName.size() <= 120
          && request.resource.data.priceLabel is string
          && request.resource.data.priceLabel.size() >= 1
          && request.resource.data.priceLabel.size() <= 60;
      }

      function hasValidProductOptionalFields() {
        return (!('imageUrl' in request.resource.data)
            || (
              request.resource.data.imageUrl is string
              && request.resource.data.imageUrl.size() <= 1500
            ))
          && (!('imagePath' in request.resource.data)
            || (
              request.resource.data.imagePath is string
              && request.resource.data.imagePath.size() <= 400
              && (
                request.resource.data.imagePath == 'merchant-products/' + request.resource.data.merchantId + '/' + productId + '/cover.jpg'
                || (
                  resource != null
                  && ('imagePath' in resource.data)
                  && request.resource.data.imagePath == resource.data.imagePath
                )
              )
            ))
          && (!('imageUploadStatus' in request.resource.data)
            || (
              request.resource.data.imageUploadStatus is string
              && isValidImageUploadStatus(request.resource.data.imageUploadStatus)
            ))
          && (!('searchKeywords' in request.resource.data)
            || (
              request.resource.data.searchKeywords is list
              && request.resource.data.searchKeywords.size() <= 40
            ))
          && (!('sortOrder' in request.resource.data)
            || request.resource.data.sortOrder is int);
      }

      function productUpdatePayloadIsValid() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return hasValidProductKeys()
          && request.resource.data.id == productId
          && (
            !('id' in resource.data)
            || request.resource.data.id == resource.data.id
          )
          && request.resource.data.merchantId == resource.data.merchantId
          && request.resource.data.ownerUserId == resource.data.ownerUserId
          && request.resource.data.sourceType == resource.data.sourceType
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.createdBy == resource.data.createdBy
          && !('merchantId' in changed)
          && !('ownerUserId' in changed)
          && !('sourceType' in changed)
          && !('createdAt' in changed)
          && !('createdBy' in changed)
          // El status de ciclo de vida se controla por backend para mantener
          // `catalogStats.activeProductCount` consistente y evitar bypass.
          && !('status' in changed)
          && request.resource.data.status == resource.data.status
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.updatedBy == request.auth.uid
          && request.resource.data.stockStatus is string
          && isValidProductStockStatus(request.resource.data.stockStatus)
          && request.resource.data.visibilityStatus is string
          && isValidProductVisibilityStatus(request.resource.data.visibilityStatus)
          && request.resource.data.status is string
          && isValidProductStatus(request.resource.data.status)
          && hasValidProductTextFields()
          && hasValidProductOptionalFields();
      }

      function isPublicProduct() {
        return resource.data.status == 'active'
          && resource.data.visibilityStatus == 'visible';
      }

      function isProductOwner() {
        return isOwnerRole()
          && isAuthenticated()
          && resource.data.ownerUserId == request.auth.uid
          && merchantBelongsToUser(resource.data.merchantId);
      }

      allow read: if isPublicProduct();
      allow read: if isProductOwner();
      allow read: if isAdmin();

      allow create: if isAdmin();
      // OWNER crea vía callable backend (`createMerchantProduct`).

      allow update: if isAdmin();
      allow update: if isProductOwner()
        && productUpdatePayloadIsValid();

      allow delete: if isAdmin();
    }

    // ─── pharmacy_duties/{dutyId} ────────────────────────────────────────────
    // Lectura pública sólo en estados operativos no cancelados.
    // Escrituras sensibles sólo por backend (Admin SDK) o admin.

    match /pharmacy_duties/{dutyId} {
      allow read: if isDutyPublicReadableStatus(resource.data.status);
      allow read: if isAuthenticated()
                     && merchantBelongsToUser(resource.data.merchantId);
      allow read: if isAdmin();

      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── pharmacy_duty_incidents/{incidentId} ───────────────────────────────
    // Escritura sólo backend/admin. Lectura limitada a farmacia dueña del duty.

    match /pharmacy_duty_incidents/{incidentId} {
      allow read: if isAdmin();
      allow read: if isOwnerRole()
        && merchantBelongsToUser(resource.data.merchantId);
      allow create, update, delete: if isAdmin();
    }

    // ─── pharmacy_duty_reassignment_rounds/{roundId} ────────────────────────
    // Escritura sólo backend/admin. Lectura owner origen o admin.

    match /pharmacy_duty_reassignment_rounds/{roundId} {
      allow read: if isAdmin();
      allow read: if isOwnerRole()
        && merchantBelongsToUser(resource.data.originMerchantId);
      allow create, update, delete: if isAdmin();
    }

    // ─── pharmacy_duty_reassignment_requests/{requestId} ────────────────────
    // Escritura sólo backend/admin. Lectura owner origen/candidata o admin.

    match /pharmacy_duty_reassignment_requests/{requestId} {
      allow read: if isAdmin();
      allow read: if isOwnerRole()
        && (
          merchantBelongsToUser(resource.data.originMerchantId)
          || merchantBelongsToUser(resource.data.candidateMerchantId)
        );
      allow create, update, delete: if isAdmin();
    }

    // ─── external_places/{externalPlaceDocId} ────────────────────────────────
    // Admin only. External seed data — not exposed publicly.

    match /external_places/{externalPlaceDocId} {
      allow read, write: if isAdmin();
    }

    // ─── import_batches/{batchId} ────────────────────────────────────────────
    // Admin only.

    match /import_batches/{batchId} {
      allow read, write: if isAdmin();
    }

    // ─── merchant_claims/{claimId} ───────────────────────────────────────────
    // Claims sensibles: acceso cliente directo denegado.
    // Flujo completo por callables backend (Admin SDK) con payload mínimo.

    match /merchant_claims/{claimId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ─── merchant_claim_private/{claimId} ────────────────────────────────────
    // Vault de sensibles/fingerprints: backend/admin only.
    // Nunca exponer a cliente.

    match /merchant_claim_private/{claimId} {
      allow read, write: if false;
      allow create, update, delete: if false;
    }

    // ─── reports/{reportId} ──────────────────────────────────────────────────
    // Authenticated users create reports. Admins read and update all.

    match /reports/{reportId} {
      allow create: if isAuthenticated()
        && request.resource.data.reportedBy == request.auth.uid;
      allow read, update: if isAdmin();
    }

    // ─── admin_configs/{configId} ────────────────────────────────────────────
    // Admin read/write. Super admin only for write on global config.

    match /admin_configs/{configId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

  }
}
